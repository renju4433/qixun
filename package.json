{
  "name": "qixun-front",
  "version": "1.0.17",
  "private": true,
  "author": "yw mao <gfel@live.cn>",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 API_ENV=prod max build",
    "analyze:dev": "cross-env ANALYZE=1 API_ENV=dev max build",
    "build": "cross-env REACT_APP_ENV=prod API_ENV=prod max build && npm run sentry:sourcemaps",
    "build:no-sentry": "cross-env REACT_APP_ENV=prod API_ENV=prod max build",
    "build:uat": "cross-env REACT_APP_ENV=uat API_ENV=prod max build",
    "dev": "max dev",
    "postinstall": "max setup",
    "mock-ws": "ts-node --project ./test/tsconfig.json ./test/ws.ts",
    "setup": "max setup",
    "start": "npm run dev",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org qixun --project qixun-front ./dist && sentry-cli sourcemaps upload --org qixun --project qixun-front ./dist"
  },
